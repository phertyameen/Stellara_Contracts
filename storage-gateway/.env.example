# Server Configuration
PORT=3000
NODE_ENV=development

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# IPFS Configuration
IPFS_NODE_URL=http://localhost:5001
IPFS_GATEWAY_URL=https://ipfs.io
IPFS_PINNING_NODES=["/ip4/127.0.0.1/tcp/4001"]

# Arweave Configuration
ARWEAVE_GATEWAY_URL=https://arweave.net
ARWEAVE_WALLET_FILE=path/to/wallet.json
ARWEAVE_API_URL=https://api.arweave.org

# Filecoin Configuration
FILECOIN_RPC_URL=https://api.node.glif.io/rpc/v1
FILECOIN_WALLET_ADDRESS=
FILECOIN_API_TOKEN=

# Cache Configuration
CACHE_TTL=3600
MEMORY_CACHE_SIZE=100
REDIS_CACHE_ENABLED=true

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY=1000
TIMEOUT=30000

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Cost Optimization
COST_OPTIMIZATION_ENABLED=true
PREFERRED_STORAGE_TIER=standard
MIN_REPLICATION_FACTOR=2

# Content Verification
CONTENT_VERIFICATION_ENABLED=true
HASH_ALGORITHM=sha256

# Dashboard
DASHBOARD_ENABLED=true
DASHBOARD_PORT=3001
