{
  "name": "stellara-storage-gateway",
  "version": "1.0.0",
  "description": "Decentralized storage gateway service with multi-network abstraction, caching, and failover",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": ["ipfs", "arweave", "filecoin", "decentralized-storage", "gateway"],
  "author": "Stellara",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "ipfs-core": "^0.18.1",
    "ipfs-http-client": "^60.0.1",
    "arweave": "^1.15.4",
        "redis": "^4.6.10",
    "ioredis": "^5.3.2",
    "node-cache": "^5.1.2",
    "crypto": "^1.0.1",
    "sha256": "^0.2.0",
    "multihashes": "^4.0.3",
    "cids": "^1.1.9",
    "axios": "^1.6.2",
    "retry": "^0.13.1",
    "p-retry": "^6.2.0",
    "p-map": "^7.0.2",
    "express-rate-limit": "^7.1.5",
    "winston": "^3.11.0",
    "joi": "^17.11.0",
    "uuid": "^9.0.1",
    "bull": "^4.12.2",
    "socket.io": "^4.7.4",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/jest": "^29.5.8",
    "@types/uuid": "^9.0.7",
    "@types/retry": "^0.12.2",
    "@types/multer": "^1.4.11",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.16"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
