  competitionId String           @map("competition_id")
  competition   TradingCompetition @relation(fields: [competitionId], references: [id])
  userId        String           @map("user_id")
  user          User             @relation(fields: [userId], references: [id])
  type          AchievementType
  title         String
  description   String
  icon          String?
  earnedAt      DateTime         @default(now()) @map("earned_at")
  shared        Boolean          @default(false)
  shareUrl      String?          @map("share_url")
  
  @@map("competition_achievements")
}

model AntiCheatFlag {
  id             String         @id @default(cuid())
  competitionId  String         @map("competition_id")
  competition    TradingCompetition @relation(fields: [competitionId], references: [id])
  userId         String         @map("user_id")
  user           User           @relation(fields: [userId], references: [id])
  type           FlagType
  severity       FlagSeverity
  description    String
  evidence       Json?
  status         FlagStatus     @default(PENDING)
  reviewedBy     String?        @map("reviewed_by")
  reviewedAt     DateTime?      @map("reviewed_at")
  action         String?
  createdAt      DateTime       @default(now()) @map("created_at")
  
  @@index([competitionId, userId])
  @@index([status])
  @@map("anti_cheat_flags")
}

model PrizeDistribution {
  id             String     @id @default(cuid())
  competitionId  String     @map("competition_id")
  competition    TradingCompetition @relation(fields: [competitionId], references: [id])
  userId         String     @map("user_id")
  user           User       @relation(fields: [userId], references: [id])
  rank           Int
  prizeAmount    Decimal    @map("prize_amount")
  currency       String     @default("USD")
  status         PrizeStatus @default(PENDING)
  transactionHash String?   @map("transaction_hash")
  distributedAt  DateTime?  @map("distributed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  
  @@index([competitionId, userId])
  @@index([status])
  @@map("prize_distributions")
}

