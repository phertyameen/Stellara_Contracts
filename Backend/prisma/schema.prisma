// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Prisma v7: datasource connection URL is configured in prisma.config.ts

generator client {
  provider = "prisma-client-js"
}

// Provider is declared here for @db attribute support.
// Connection URL is in prisma.config.ts (Prisma v7+)
datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(cuid())
  name            String?
  walletAddress   String   @unique @map("wallet_address")
  profileData     Json?    @map("profile_data")
  reputationScore Int      @default(0) @map("reputation_score")
  trustScore      Int      @default(500) @map("trust_score")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Notification fields
  phoneNumber      String? @unique @map("phone_number")
  email            String? @unique @map("email_encrypted")
  pushSubscription Json?   @map("push_subscription")

  // Encrypted PII fields
  phoneEncrypted   Json? @map("phone_encrypted")
  ssnEncrypted     Json? @map("ssn_encrypted")
  addressEncrypted Json? @map("address_encrypted")

  // Auth fields
  roles              Role[]  @default([USER])
  hashedRefreshToken String? @map("hashed_refresh_token")

  // Tenant relation (optional — null for platform-level users)
  tenantId String? @map("tenant_id")
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  // Relations
  createdProjects      Project[]            @relation("ProjectCreator")
  contributions        Contribution[]
  reputationHistory    ReputationHistory[]
  notificationSettings NotificationSetting?
  notifications        Notification[]
  proposals            TransactionProposal[]
  tenantMembers       TenantMember[]

  @@unique([tenantId, email])
  @@unique([tenantId, walletAddress])
  @@index([tenantId, id])
  @@index([tenantId, email])
  @@index([tenantId, walletAddress])
  @@map("users")
}

model Project {
  id           String        @id @default(cuid())
  contractId   String        @unique @map("contract_id")
  creatorId    String        @map("creator_id")
  creator      User          @relation("ProjectCreator", fields: [creatorId], references: [id])
  title        String
  description  String?
  category     String
  goal         BigInt
  currentFunds BigInt        @default(0) @map("current_funds")
  deadline     DateTime
  ipfsHash     String?       @map("ipfs_hash")
  status       ProjectStatus @default(ACTIVE)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  // Relations
  contributions Contribution[]
  milestones    Milestone[]

  @@map("projects")
}

model Contribution {
  id              String   @id @default(cuid())
  transactionHash String   @unique @map("transaction_hash")
  investorId      String   @map("investor_id")
  investor        User     @relation(fields: [investorId], references: [id])
  projectId       String   @map("project_id")
  project         Project  @relation(fields: [projectId], references: [id])
  amount          BigInt
  timestamp       DateTime @default(now())
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("contributions")
}

model Milestone {
  id             String          @id @default(cuid())
  projectId      String          @map("project_id")
  project        Project         @relation(fields: [projectId], references: [id])
  title          String
  description    String?
  fundingAmount  BigInt          @map("funding_amount")
  status         MilestoneStatus @default(PENDING)
  completionDate DateTime?       @map("completion_date")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@map("milestones")
}

model ReputationHistory {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  scoreChange Int      @map("score_change")
  reason      String
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("reputation_history")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  SUSPENDED
}

enum MilestoneStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  FUNDED
}

model LedgerCursor {
  id             String   @id @default(cuid())
  network        String   @unique
  lastLedgerSeq  Int      @map("last_ledger_seq")
  lastLedgerHash String?  @map("last_ledger_hash")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("ledger_cursors")
}

model ProcessedEvent {
  id              String   @id @default(cuid())
  eventId         String   @unique @map("event_id")
  network         String
  ledgerSeq       Int      @map("ledger_seq")
  contractId      String   @map("contract_id")
  eventType       String   @map("event_type")
  transactionHash String   @map("transaction_hash")
  contractType    String?  @map("contract_type")
  decodedData     Json?    @map("decoded_data")
  abiVersion      String?  @map("abi_version")
  processedAt     DateTime @default(now()) @map("processed_at")

  @@index([network, ledgerSeq])
  @@index([contractId, eventType])
  @@map("processed_events")
}

model ContractAbiRegistry {
  id              String               @id @default(uuid())
  contractAddress String               @unique @map("contract_address")
  contractType    String               @map("contract_type")
  displayName     String               @map("display_name")
  network         String               @default("stellar")
  description     String?
  status          AbiRegistryStatus    @default(ACTIVE)
  currentVersion  String?              @map("current_version")
  metadata        Json?
  createdBy       String?              @map("created_by")
  updatedBy       String?              @map("updated_by")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  versions        ContractAbiVersion[]

  @@index([contractType, network])
  @@index([status, updatedAt])
  @@map("contract_abi_registries")
}

model ContractAbiVersion {
  id              String              @id @default(uuid())
  registryId      String              @map("registry_id")
  registry        ContractAbiRegistry @relation(fields: [registryId], references: [id], onDelete: Cascade)
  version         String
  isCurrent       Boolean             @default(false) @map("is_current")
  isDeprecated    Boolean             @default(false) @map("is_deprecated")
  abiSchema       Json                @map("abi_schema")
  contractSchema  Json                @map("contract_schema")
  functionSchemas Json                @map("function_schemas")
  eventSchemas    Json                @map("event_schemas")
  changelog       String?
  compatibility   Json?
  createdBy       String?             @map("created_by")
  createdAt       DateTime            @default(now()) @map("created_at")

  @@unique([registryId, version])
  @@index([registryId, isCurrent])
  @@index([version])
  @@map("contract_abi_versions")
}

model IndexerLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  metadata  Json?
  timestamp DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")

  @@index([timestamp])
  @@index([level])
  @@map("indexer_logs")
}

model NotificationSetting {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  user                User     @relation(fields: [userId], references: [id])
  emailEnabled        Boolean  @default(true) @map("email_enabled")
  pushEnabled         Boolean  @default(false) @map("push_enabled")
  smsEnabled          Boolean  @default(false) @map("sms_enabled")
  websocketEnabled    Boolean  @default(true) @map("websocket_enabled")
  notifyContributions Boolean  @default(true) @map("notify_contributions")
  notifyMilestones    Boolean  @default(true) @map("notify_milestones")
  notifyDeadlines     Boolean  @default(true) @map("notify_deadlines")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("notification_settings")
}

model Notification {
  id         String                 @id @default(cuid())
  userId     String                 @map("user_id")
  user       User                   @relation(fields: [userId], references: [id])
  type       NotificationType
  title      String
  message    String
  read       Boolean                @default(false)
  data       Json? // Optional metadata (e.g., projectId)
  createdAt  DateTime               @default(now()) @map("created_at")
  deliveries NotificationDelivery[]

  @@index([userId])
  @@map("notifications")
}

model NotificationDelivery {
  id             String              @id @default(cuid())
  notificationId String              @map("notification_id")
  notification   Notification        @relation(fields: [notificationId], references: [id])
  channel        NotificationChannel
  status         DeliveryStatus      @default(PENDING)
  errorMessage   String?             @map("error_message")
  attempts       Int                 @default(0)
  lastAttemptAt  DateTime?           @map("last_attempt_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@map("notification_deliveries")
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  WEBSOCKET
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

model EmailOutbox {
  id        String      @id @default(cuid())
  to        String
  subject   String
  html      String
  status    EmailStatus @default(PENDING)
  attempts  Int         @default(0)
  lastError String?     @map("last_error")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([status])
  @@map("email_outbox")
}

enum NotificationType {
  CONTRIBUTION
  MILESTONE
  DEADLINE
  SYSTEM
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  USER
  VIEWER
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
  ARCHIVED
}

enum TenantPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum ApiOveragePolicy {
  HARD_STOP
  BILL_OVERAGE
}

model Tenant {
  id        String       @id @default(cuid())
  name      String       @unique
  slug      String       @unique
  status    TenantStatus @default(ACTIVE)
  plan      TenantPlan   @default(FREE)
  metadata  Json?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  settings             TenantSettings?
  calls                Call[]
  stakeLedgers         StakeLedger[]
  claims               Claim[]
  pools                Pool[]
  users                User[]
  auditLogs            TenantAuditLog[]
  tenantMembers        TenantMember[]
  subscription         Subscription?
  webhookSubscriptions WebhookSubscription[]
  webhookEvents        WebhookEvent[]

  @@index([status])
  @@map("tenants")
}

model TenantSettings {
  id                    String           @id @default(cuid())
  tenantId              String           @unique @map("tenant_id")
  tenant                Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  maxUsers              Int              @default(10) @map("max_users")
  maxProjects           Int              @default(5) @map("max_projects")
  apiCallsPerMonthLimit Int              @default(100000) @map("api_calls_per_month_limit")
  storageGbLimit        Int              @default(100) @map("storage_gb_limit")
  apiOveragePolicy      ApiOveragePolicy @default(HARD_STOP) @map("api_overage_policy")
  allowPublicProjects   Boolean          @default(true) @map("allow_public_projects")
  notificationsEnabled  Boolean          @default(true) @map("notifications_enabled")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  @@map("tenant_settings")
}

model TenantAuditLog {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  action    String
  actorId   String?  @map("actor_id")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([action])
  @@map("tenant_audit_logs")
}

enum Permission {
  // Project Permissions
  CREATE_PROJECT
  UPDATE_PROJECT
  DELETE_PROJECT
  VIEW_PROJECT

  // Contribution Permissions
  MAKE_CONTRIBUTION
  VIEW_CONTRIBUTION

  // User/Admin Permissions
  MANAGE_USERS
  MANAGE_ROLES
  VIEW_SENSITIVE_DATA

  // System Permissions
  MANAGE_SYSTEM
}

model TokenBlacklist {
  id        String   @id @default(cuid())
  token     String   @unique // The exact JWT access token string
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("token_blacklist")
}

model MultiSigAccount {
  id              String   @id @default(cuid())
  accountId       String   @unique @map("account_id") // Stellar account ID
  name            String?
  thresholds      Json     // { masterWeight, lowThreshold, medThreshold, highThreshold }
  signers         Json     // Array of { key, weight, type }
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  proposals       TransactionProposal[]

  @@map("multi_sig_accounts")
}

model TransactionProposal {
  id              String   @id @default(cuid())
  multiSigId      String   @map("multi_sig_id")
  multiSig        MultiSigAccount @relation(fields: [multiSigId], references: [id])
  creatorId       String   @map("creator_id")
  creator         User     @relation(fields: [creatorId], references: [id])
  xdr             String   // The unsigned or partially signed base64 XDR
  description     String?
  status          ProposalStatus @default(PENDING)
  expiresAt       DateTime @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  signatures      ProposalSignature[]

  @@map("transaction_proposals")
}

model ProposalSignature {
  id              String   @id @default(cuid())
  proposalId      String   @map("proposal_id")
  proposal        TransactionProposal @relation(fields: [proposalId], references: [id])
  signerAddress   String   @map("signer_address") // Who signed it
  signature       String   // The actual signature part
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([proposalId, signerAddress])
  @@map("proposal_signatures")
}

enum ProposalStatus {
  PENDING
  READY
  SUBMITTED
  EXPIRED
  FAILED
}

model EncryptionAuditLog {
  id             String   @id @default(cuid())
  keyId          String   @map("key_id")
  userId         String?  @map("user_id")
  action         String // ENCRYPT, DECRYPT, KEY_ROTATE, KEY_REVOKE
  field          String?  @map("field_name")
  table          String?  @map("table_name")
  timestamp      DateTime @default(now())
  ipAddress      String   @map("ip_address")
  userAgent      String?  @map("user_agent")
  success        Boolean  @default(false)
  error          String?  @map("error_message")
  processingTime Int      @map("processing_time_ms")

  @@index([timestamp])
  @@index([keyId])
  @@index([action])
  @@index([success])
  @@map("encryption_audit_logs")
}

model Call {
  id          String      @id @default(uuid())
  tenantId    String
  description String
  outcome     CallOutcome @default(PENDING)
  resolvedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  stakes StakeLedger[]

  @@index([tenantId, id])
  @@index([tenantId, outcome])
  @@index([tenantId, createdAt])
  @@index([tenantId, expiresAt])
  @@map("calls")
}

model StakeLedger {
  id               String           @id @default(uuid())
  tenantId         String
  callId           String
  userAddress      String
  amount           Decimal          @db.Decimal(18, 4)
  position         Position
  profitLoss       Decimal?         @db.Decimal(18, 4)
  transactionHash  String?
  resolutionStatus ResolutionStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  call   Call   @relation(fields: [callId], references: [id], onDelete: Restrict)

  @@unique([tenantId, transactionHash])
  @@index([tenantId, id])
  @@index([tenantId, callId])
  @@index([tenantId, userAddress])
  @@index([tenantId, createdAt])
  @@map("stake_ledger")
}

model Claim {
  id          String      @id @default(uuid())
  tenantId    String
  poolId      String?
  userAddress String
  amount      Decimal     @db.Decimal(18, 4)
  status      ClaimStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  pool   Pool?  @relation(fields: [poolId], references: [id], onDelete: SetNull)

  @@index([tenantId, id])
  @@index([tenantId, poolId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, userAddress])
  @@map("claims")
}

model Pool {
  id                 String   @id @default(uuid())
  tenantId           String
  name               String
  totalCapacity      Decimal  @default(0) @db.Decimal(18, 4)
  lockedAmount       Decimal  @default(0) @db.Decimal(18, 4)
  availableLiquidity Decimal  @default(0) @db.Decimal(18, 4)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  claims Claim[]

  @@unique([tenantId, name])
  @@index([tenantId, id])
  @@index([tenantId, name])
  @@index([tenantId, createdAt])
  @@map("pools")
}

enum CallOutcome {
  YES
  NO
  PENDING
}

enum Position {
  YES
  NO
}

enum ResolutionStatus {
  PENDING
  RESOLVED
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

model TenantMember {
  id        String     @id @default(uuid())
  tenantId  String
  userId    String
  role      TenantRole @default(MEMBER)
  createdAt DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, role])
  @@map("tenant_members")
}

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
}

// ─── Centralized Config Management ───────────────────────────────────────────

model ConfigEntry {
  id        String      @id @default(uuid())
  key       String
  value     String
  scope     ConfigScope @default(GLOBAL)
  tenantId  String?     @map("tenant_id")
  userId    String?     @map("user_id")
  encrypted Boolean     @default(false)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@unique([key, scope, tenantId, userId])
  @@index([scope, tenantId])
  @@index([key])
  @@map("config_entries")
}

model FeatureFlag {
  id         String   @id @default(uuid())
  key        String
  enabled    Boolean  @default(false)
  tenantId   String?  @map("tenant_id")
  rolloutPct Int      @default(100) @map("rollout_pct")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([key, tenantId])
  @@index([key])
  @@index([tenantId])
  @@map("feature_flags")
}

model ConfigAuditLog {
  id        String      @id @default(uuid())
  key       String
  oldValue  String?     @map("old_value")
  newValue  String?     @map("new_value")
  scope     ConfigScope
  tenantId  String?     @map("tenant_id")
  actorId   String?     @map("actor_id")
  action    String // SET, DELETE, ROTATE_SECRET
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([key])
  @@index([tenantId])
  @@index([createdAt])
  @@map("config_audit_logs")
}

model WebhookSubscription {
  id              String                    @id @default(uuid())
  tenantId        String?                   @map("tenant_id")
  name            String
  description     String?
  url             String
  secret          String
  status          WebhookSubscriptionStatus @default(ACTIVE)
  eventFilters    Json                      @map("event_filters")
  payloadFields   Json?                     @map("payload_fields")
  customHeaders   Json?                     @map("custom_headers")
  createdBy       String?                   @map("created_by")
  lastTriggeredAt DateTime?                 @map("last_triggered_at")
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  tenant     Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  deliveries WebhookDelivery[]

  @@index([tenantId, status])
  @@index([status])
  @@map("webhook_subscriptions")
}

model WebhookEvent {
  id         String   @id @default(uuid())
  tenantId   String?  @map("tenant_id")
  eventType  String   @map("event_type")
  source     String   @default("platform")
  payload    Json
  metadata   Json?
  occurredAt DateTime @default(now()) @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant     Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  deliveries WebhookDelivery[]

  @@index([tenantId, eventType])
  @@index([eventType, occurredAt])
  @@map("webhook_events")
}

model WebhookDelivery {
  id               String                @id @default(uuid())
  subscriptionId   String                @map("subscription_id")
  eventId          String                @map("event_id")
  status           WebhookDeliveryStatus @default(PENDING)
  attempts         Int                   @default(0)
  maxAttempts      Int                   @default(10) @map("max_attempts")
  nextAttemptAt    DateTime              @default(now()) @map("next_attempt_at")
  lastAttemptAt    DateTime?             @map("last_attempt_at")
  deliveredAt      DateTime?             @map("delivered_at")
  lastResponseCode Int?                  @map("last_response_code")
  lastResponseBody String?               @map("last_response_body")
  errorMessage     String?               @map("error_message")
  signature        String?               @map("signature")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  event        WebhookEvent        @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([subscriptionId, status])
  @@index([eventId])
  @@map("webhook_deliveries")
}

enum ConfigScope {
  GLOBAL
  TENANT
  USER
}

model AuditLog {
  id            String      @id @default(uuid())
  correlationId String?     @map("correlation_id")
  tenantId      String?     @map("tenant_id")
  userId        String?     @map("user_id")
  action        AuditAction
  entityType    String      @map("entity_type")
  entityId      String?     @map("entity_id")
  method        String? // HTTP method (GET, POST, PUT, DELETE)
  path          String? // Request path
  statusCode    Int?        @map("status_code")
  ipAddress     String?     @map("ip_address")
  userAgent     String?     @map("user_agent")
  requestBody   Json?       @map("request_body")
  responseBody  Json?       @map("response_body")
  previousState Json?       @map("previous_state")
  newState      Json?       @map("new_state")
  changedFields String[]    @map("changed_fields")
  metadata      Json?
  duration      Int? // Duration in milliseconds
  errorMessage  String?     @map("error_message")
  checksum      String? // SHA-256 hash for tamper detection
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
  @@index([correlationId])
  @@index([createdAt])
  @@index([statusCode])
  @@map("audit_logs")
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  SYSTEM_EVENT
  API_CALL
  ERROR
  ACCESS_DENIED
  DATA_CHANGE
}

model AuditRetentionPolicy {
  id              String    @id @default(uuid())
  name            String    @unique
  tenantId        String?   @map("tenant_id")
  retentionDays   Int       @default(90) @map("retention_days")
  entityTypes     String[]  @map("entity_types")
  actions         String[] // AuditAction values to apply policy to
  archiveEnabled  Boolean   @default(false) @map("archive_enabled")
  archiveLocation String?   @map("archive_location")
  isActive        Boolean   @default(true) @map("is_active")
  lastExecutedAt  DateTime? @map("last_executed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([isActive])
  @@map("audit_retention_policies")
}

// ─── Payment System Models ───────────────────────────────────────────────────

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  UNPAID
  TRIALING
  PAUSED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  UNCOLLECTIBLE
  VOID
}

enum PaymentEventType {
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_UPDATED
  SUBSCRIPTION_CANCELLED
  INVOICE_CREATED
  INVOICE_PAID
  INVOICE_PAYMENT_FAILED
  PAYMENT_METHOD_ATTACHED
  PAYMENT_METHOD_DETACHED
  USAGE_RECORDED
  DUNNING_STARTED
  DUNNING_RESOLVED
  DUNNING_FAILED
}

model SubscriptionPlan {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String?
  stripePriceId String   @unique @map("stripe_price_id")
  amount        Int // Amount in cents
  currency      String   @default("usd")
  interval      String   @default("month") // month, year
  features      Json? // Feature flags and limits
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                   String             @id @default(uuid())
  tenantId             String             @unique @map("tenant_id")
  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId               String             @map("plan_id")
  plan                 SubscriptionPlan   @relation(fields: [planId], references: [id])
  stripeSubscriptionId String             @unique @map("stripe_subscription_id")
  stripeCustomerId     String             @map("stripe_customer_id")
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodStart   DateTime           @map("current_period_start")
  currentPeriodEnd     DateTime           @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  canceledAt           DateTime?          @map("canceled_at")
  trialStart           DateTime?          @map("trial_start")
  trialEnd             DateTime?          @map("trial_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  invoices        Invoice[]
  usageRecords    UsageRecord[]
  paymentEvents   PaymentEvent[]
  dunningAttempts DunningAttempt[]

  @@index([tenantId])
  @@index([status])
  @@index([stripeCustomerId])
  @@map("subscriptions")
}

model UsageRecord {
  id                  String       @id @default(uuid())
  subscriptionId      String       @map("subscription_id")
  subscription        Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  tenantId            String       @map("tenant_id")
  metricName          String       @map("metric_name") // api_calls, storage_gb, compute_hours
  quantity            Int
  timestamp           DateTime     @default(now())
  stripeUsageRecordId String?      @map("stripe_usage_record_id")
  createdAt           DateTime     @default(now()) @map("created_at")

  @@index([subscriptionId])
  @@index([tenantId])
  @@index([metricName])
  @@index([timestamp])
  @@map("usage_records")
}

model Invoice {
  id               String        @id @default(uuid())
  subscriptionId   String        @map("subscription_id")
  subscription     Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  tenantId         String        @map("tenant_id")
  stripeInvoiceId  String        @unique @map("stripe_invoice_id")
  status           InvoiceStatus @default(DRAFT)
  amountDue        Int           @map("amount_due") // in cents
  amountPaid       Int           @default(0) @map("amount_paid")
  currency         String        @default("usd")
  pdfUrl           String?       @map("pdf_url")
  hostedInvoiceUrl String?       @map("hosted_invoice_url")
  invoiceNumber    String?       @map("invoice_number")
  dueDate          DateTime?     @map("due_date")
  paidAt           DateTime?     @map("paid_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@index([subscriptionId])
  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("invoices")
}

model PaymentMethod {
  id                    String   @id @default(uuid())
  tenantId              String   @unique @map("tenant_id")
  stripePaymentMethodId String   @unique @map("stripe_payment_method_id")
  type                  String // card, bank_transfer, etc.
  brand                 String? // visa, mastercard, etc.
  last4                 String?
  expMonth              Int?     @map("exp_month")
  expYear               Int?     @map("exp_year")
  isDefault             Boolean  @default(true) @map("is_default")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("payment_methods")
}

model PaymentEvent {
  id             String           @id @default(uuid())
  subscriptionId String?          @map("subscription_id")
  subscription   Subscription?    @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  tenantId       String           @map("tenant_id")
  eventType      PaymentEventType @map("event_type")
  stripeEventId  String?          @map("stripe_event_id")
  metadata       Json?
  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([subscriptionId])
  @@index([tenantId])
  @@index([eventType])
  @@index([createdAt])
  @@map("payment_events")
}

model DunningAttempt {
  id             String       @id @default(uuid())
  subscriptionId String       @map("subscription_id")
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  tenantId       String       @map("tenant_id")
  invoiceId      String       @map("invoice_id")
  attemptNumber  Int          @map("attempt_number")
  status         String // pending, succeeded, failed
  nextRetryAt    DateTime?    @map("next_retry_at")
  emailSentAt    DateTime?    @map("email_sent_at")
  resolvedAt     DateTime?    @map("resolved_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([subscriptionId])
  @@index([tenantId])
  @@index([status])
  @@index([nextRetryAt])
  @@map("dunning_attempts")
}

enum WebhookSubscriptionStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum WebhookDeliveryStatus {
  PENDING
  RETRYING
  DELIVERED
  FAILED
}

enum AbiRegistryStatus {
  ACTIVE
  DEPRECATED
  ARCHIVED
}
