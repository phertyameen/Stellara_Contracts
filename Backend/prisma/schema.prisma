// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  walletAddress   String   @unique @map("wallet_address")
  profileData     Json?    @map("profile_data")
  reputationScore Int      @default(0) @map("reputation_score")
  trustScore      Int      @default(500) @map("trust_score")
  reputationLevel String   @default("BRONZE") @map("reputation_level")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Notification fields
  email            String? @unique
  pushSubscription Json?   @map("push_subscription")

  // Relations
  createdProjects      Project[]            @relation("ProjectCreator")
  contributions        Contribution[]
  reputationHistory    ReputationHistory[]


  // Dispute Relations
  reputationDisputes   ReputationDispute[]
  moderatedDisputes    ReputationDispute[] @relation("DisputeModerator")
  disputeComments      DisputeComment[]
  resolvedDisputes     DisputeResolution[] @relation("ResolutionModerator")

  @@map("users")
}

model Project {
  id           String        @id @default(cuid())
  contractId   String        @unique @map("contract_id")
  creatorId    String        @map("creator_id")
  creator      User          @relation("ProjectCreator", fields: [creatorId], references: [id])
  title        String
  description  String?
  category     String
  goal         BigInt
  currentFunds BigInt        @default(0) @map("current_funds")
  deadline     DateTime
  ipfsHash     String?       @map("ipfs_hash")
  status       ProjectStatus @default(ACTIVE)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  // Relations
  contributions Contribution[]
  milestones    Milestone[]
  publicGoodsProject PublicGoodsProject?

  @@map("projects")
}

model Contribution {
  id              String   @id @default(cuid())
  transactionHash String   @unique @map("transaction_hash")
  investorId      String   @map("investor_id")
  investor        User     @relation(fields: [investorId], references: [id])
  projectId       String   @map("project_id")
  project         Project  @relation(fields: [projectId], references: [id])
  amount          BigInt
  timestamp       DateTime @default(now())
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("contributions")
}

model Milestone {
  id             String          @id @default(cuid())
  projectId      String          @map("project_id")
  project        Project         @relation(fields: [projectId], references: [id])
  contractMilestoneId String?    @map("contract_milestone_id")
  title          String
  description    String?
  fundingAmount  BigInt          @map("funding_amount")
  status         MilestoneStatus @default(PENDING)
  completionDate DateTime?       @map("completion_date")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@unique([projectId, contractMilestoneId])
  @@index([projectId, contractMilestoneId])
  @@map("milestones")
}

model ReputationHistory {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  scoreChange Int      @map("score_change")
  reason      String
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("reputation_history")
}

model ReputationActivity {
  id           String             @id @default(cuid())
  subjectId    String             @map("subject_id")
  subject      User               @relation("ReputationSubject", fields: [subjectId], references: [id])
  actorId      String?            @map("actor_id")
  actor        User?              @relation("ReputationActor", fields: [actorId], references: [id])
  activityType ActivityType       @map("activity_type")
  value        Decimal            @db.Decimal(18, 4)
  referenceId  String?            @map("reference_id")
  occurredAt   DateTime           @map("occurred_at")
  createdAt    DateTime           @default(now())

  // Dispute Relations
  reputationDisputes ReputationDispute[]

  @@index([subjectId])
  @@index([subjectId, activityType])
  @@index([occurredAt])
  @@map("reputation_activities")
}

model ReputationScore {
  id                     String   @id @default(cuid())
  subjectId              String   @unique @map("subject_id")
  subject                User     @relation(fields: [subjectId], references: [id])
  compositeScore         Decimal  @map("composite_score") @db.Decimal(6, 2)
  successRateScore       Decimal  @map("success_rate_score") @db.Decimal(6, 2)
  peerRatingScore        Decimal  @map("peer_rating_score") @db.Decimal(6, 2)
  contributionSizeScore  Decimal  @map("contribution_size_score") @db.Decimal(6, 2)
  communityFeedbackScore Decimal  @map("community_feedback_score") @db.Decimal(6, 2)
  reliabilityScore       Decimal  @default(50) @map("reliability_score") @db.Decimal(6, 2)
  expertiseScore         Decimal  @default(0) @map("expertise_score") @db.Decimal(6, 2)
  communityScore         Decimal  @default(50) @map("community_score") @db.Decimal(6, 2)
  activityCount          Int      @map("activity_count")
  lowConfidence          Boolean  @default(false) @map("low_confidence")
  calculatedAt           DateTime @updatedAt @map("calculated_at")

  @@map("reputation_scores")
}

model ReputationDecayHistory {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  previousScore   Int      @map("previous_score")
  newScore        Int      @map("new_score")
  scoreChange     Int      @map("score_change")
  decayFactor     Decimal  @map("decay_factor") @db.Decimal(6, 4)
  activitiesCount Int      @map("activities_count")
  exempted        Boolean  @default(false)
  reason          String
  occurredAt      DateTime @default(now()) @map("occurred_at")

  @@index([userId])
  @@index([occurredAt])
  @@map("reputation_decay_history")
}

}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  SUSPENDED
}

enum MilestoneStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  FUNDED
}

model LedgerCursor {
  id             String   @id @default(cuid())
  network        String   @unique
  lastLedgerSeq  Int      @map("last_ledger_seq")
  lastLedgerHash String?  @map("last_ledger_hash")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("ledger_cursors")
}

model ProcessedEvent {
  id              String   @id @default(cuid())
  eventId         String   @unique @map("event_id")
  network         String
  ledgerSeq       Int      @map("ledger_seq")
  contractId      String   @map("contract_id")
  eventType       String   @map("event_type")
  transactionHash String   @map("transaction_hash")
  processedAt     DateTime @default(now()) @map("processed_at")

  @@index([network, ledgerSeq])
  @@index([contractId, eventType])
  @@map("processed_events")
}

model IndexerLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  metadata  Json?
  timestamp DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")

  @@index([timestamp])
  @@index([level])
  @@map("indexer_logs")
}

model NotificationSetting {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  user                User     @relation(fields: [userId], references: [id])
  emailEnabled        Boolean  @default(true) @map("email_enabled")
  pushEnabled         Boolean  @default(false) @map("push_enabled")
  notifyContributions Boolean  @default(true) @map("notify_contributions")
  notifyMilestones    Boolean  @default(true) @map("notify_milestones")
  notifyDeadlines     Boolean  @default(true) @map("notify_deadlines")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("notification_settings")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  data      Json? // Optional metadata (e.g., projectId)
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId])
  @@map("notifications")
}

model EmailOutbox {
  id        String      @id @default(cuid())
  to        String
  subject   String
  html      String
  status    EmailStatus @default(PENDING)
  attempts  Int         @default(0)
  lastError String?     @map("last_error")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([status])
  @@map("email_outbox")
}

model NotificationOutbox {
  id             String              @id @default(cuid())
  notificationId String?             @map("notification_id")
  userId         String              @map("user_id")
  channel        NotificationChannel
  status         DeliveryStatus      @default(PENDING)
  dedupKey       String              @unique @map("dedup_key")
  payload        Json
  attempts       Int                 @default(0)
  maxAttempts    Int                 @default(3) @map("max_attempts")
  nextRetryAt    DateTime            @default(now()) @map("next_retry_at")
  lastAttemptAt  DateTime?           @map("last_attempt_at")
  retryDisabled  Boolean             @default(false) @map("retry_disabled")
  lastError      String?             @map("last_error")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@index([status, nextRetryAt])
  @@index([userId, channel])
  @@map("notification_outbox")
}

enum NotificationType {
  CONTRIBUTION
  MILESTONE
  DEADLINE
  SYSTEM
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationChannel {
  EMAIL
  PUSH
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
}

// Insurance Module Models

enum RiskType {
  PROJECT_FAILURE
  SMART_CONTRACT_EXPLOIT
  MARKET_VOLATILITY
  PARAMETRIC_WEATHER
}

enum PolicyStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  CLAIMED
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model InsurancePolicy {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id])
  poolId         String    @map("pool_id")
  pool           InsurancePool @relation(fields: [poolId], references: [id])
  riskType       RiskType  @map("risk_type")
  premium        Decimal   @map("premium")
  coverageAmount Decimal   @map("coverage_amount")
  status         PolicyStatus @default(ACTIVE)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  claims         Claim[]

  @@map("insurance_policies")
}

model InsurancePool {
  id            String   @id @default(cuid())
  name          String
  capital       Decimal  @default(0)
  lockedCapital Decimal  @default(0) @map("locked_capital")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  insurancePolicies    InsurancePolicy[]
  reinsuranceContracts ReinsuranceContract[]
  claims               Claim[]

  @@map("insurance_pools")
}

model Claim {
  id           String      @id @default(cuid())
  policyId     String      @map("policy_id")
  policy       InsurancePolicy @relation(fields: [policyId], references: [id])
  poolId       String?     @map("pool_id")
  pool         InsurancePool? @relation(fields: [poolId], references: [id])
  claimAmount  Decimal     @map("claim_amount")
  status       ClaimStatus @default(PENDING)
  payoutAmount Decimal?    @map("payout_amount")
  createdAt    DateTime    @default(now()) @map("created_at")

  @@map("claims")
}

model ReinsuranceContract {
  id             String   @id @default(cuid())
  poolId         String   @map("pool_id")
  pool           InsurancePool @relation(fields: [poolId], references: [id])
  coverageLimit  Decimal  @map("coverage_limit")
  premiumRate    Decimal  @map("premium_rate")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("reinsurance_contracts")
}


  COMPLETED
  FAILED
}

enum AccountingProvider {
  QUICKBOOKS
  XERO
  FRESHBOOKS
  WAVE
}

// Regenerative Finance Models

model FundingRound {
  id                String            @id @default(cuid())
  title             String
  description       String?
  type              FundingRoundType  @default(QUADRATIC)
  status            FundingRoundStatus @default(UPCOMING)
  startTime         DateTime          @map("start_time")
  endTime           DateTime          @map("end_time")
  matchingPool      BigInt            @default(0) @map("matching_pool")
  totalContributions BigInt           @default(0) @map("total_contributions")
  totalMatched      BigInt            @default(0) @map("total_matched")
  metadata          Json?             @map("metadata")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  // Relations
  projects          FundingRoundProject[]
  contributions      QuadraticContribution[]
  impactCertificates ImpactCertificate[]
  poolAllocations   PoolAllocation[]

  @@map("funding_rounds")
}

model PublicGoodsProject {
  id                String            @id @id @default(cuid())
  projectId         String?           @unique @map("project_id")
  project           Project?          @relation(fields: [projectId], references: [id])
  title             String
  description       String
  category          String
  walletAddress     String            @map("wallet_address")
  impactMetrics     Json?             @map("impact_metrics")
  verificationData  Json?             @map("verification_data")
  status            ProjectStatus      @default(ACTIVE)
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  // Relations
  roundProjects     FundingRoundProject[]
  contributions     QuadraticContribution[]
  impactCertificates ImpactCertificate[]
  retroactiveFunding RetroactiveFunding[]

  @@map("public_goods_projects")
}

model FundingRoundProject {
  id                   String     @id @default(cuid())
  fundingRoundId       String     @map("funding_round_id")
  fundingRound         FundingRound @relation(fields: [fundingRoundId], references: [id])
  publicGoodsProjectId String     @map("public_goods_project_id")
  publicGoodsProject   PublicGoodsProject @relation(fields: [publicGoodsProjectId], references: [id])
  uniqueContributors   Int        @default(0) @map("unique_contributors")
  totalContributions   BigInt     @default(0) @map("total_contributions")
  matchedAmount        BigInt     @default(0) @map("matched_amount")
  status               ProjectParticipationStatus @default(APPROVED)
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")

  // Relations
  contributions QuadraticContribution[]

  @@unique([fundingRoundId, publicGoodsProjectId])
  @@map("funding_round_projects")
}

model QuadraticContribution {
  id                   String   @id @default(cuid())
  fundingRoundId       String   @map("funding_round_id")
  fundingRound         FundingRound @relation(fields: [fundingRoundId], references: [id])
  publicGoodsProjectId String   @map("public_goods_project_id")
  publicGoodsProject   PublicGoodsProject @relation(fields: [publicGoodsProjectId], references: [id])
  fundingRoundProjectId String? @map("funding_round_project_id")
  fundingRoundProject FundingRoundProject? @relation(fields: [fundingRoundProjectId], references: [id])
  contributorAddress   String   @map("contributor_address")
  amount               BigInt
  voiceCredits         BigInt   @default(0) @map("voice_credits")
  transactionHash      String   @unique @map("transaction_hash")
  timestamp            DateTime @default(now())
  createdAt            DateTime @default(now()) @map("created_at")

  @@index([fundingRoundId, contributorAddress])
  @@index([publicGoodsProjectId])
  @@map("quadratic_contributions")
}

model ImpactCertificate {
  id                   String              @id @default(cuid())
  tokenId              String              @unique @map("token_id")
  fundingRoundId       String              @map("funding_round_id")
  fundingRound         FundingRound        @relation(fields: [fundingRoundId], references: [id])
  publicGoodsProjectId String              @map("public_goods_project_id")
  publicGoodsProject   PublicGoodsProject  @relation(fields: [publicGoodsProjectId], references: [id])
  issuerAddress        String              @map("issuer_address")
  holderAddress        String              @map("holder_address")
  impactMetrics        Json                @map("impact_metrics")
  verificationData     Json?               @map("verification_data")
  status               CertificateStatus   @default(ACTIVE)
  issuedAt             DateTime            @default(now()) @map("issued_at")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  @@map("impact_certificates")
}

model RetroactiveFunding {
  id                   String              @id @default(cuid())
  publicGoodsProjectId String              @map("public_goods_project_id")
  publicGoodsProject   PublicGoodsProject  @relation(fields: [publicGoodsProjectId], references: [id])
  evaluatorAddress     String              @map("evaluator_address")
  impactScore          Decimal             @map("impact_score")
  fundingAmount        BigInt              @map("funding_amount")
  evaluationCriteria   Json                @map("evaluation_criteria")
  supportingEvidence   Json?               @map("supporting_evidence")
  status               FundingStatus       @default(PENDING)
  evaluatedAt          DateTime            @default(now()) @map("evaluated_at")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  @@map("retroactive_funding")
}

model MatchingPool {
  id                   String            @id @default(cuid())
  name                 String
  description          String?
  totalAmount          BigInt            @map("total_amount")
  allocatedAmount      BigInt            @default(0) @map("allocated_amount")
  source               MatchingPoolSource @default(PROTOCOL_FEES)
  percentageFee        Decimal           @default(0.01) @map("percentage_fee")
  isActive             Boolean           @default(true) @map("is_active")
  metadata             Json?             @map("metadata")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  // Relations
  allocations          PoolAllocation[]

  @@map("matching_pools")
}

model PoolAllocation {
  id                   String       @id @default(cuid())
  matchingPoolId       String       @map("matching_pool_id")
  matchingPool         MatchingPool @relation(fields: [matchingPoolId], references: [id])
  fundingRoundId       String?      @map("funding_round_id")
  fundingRound         FundingRound? @relation(fields: [fundingRoundId], references: [id])
  amount               BigInt
  allocatedAt          DateTime     @default(now()) @map("allocated_at")
  createdAt            DateTime     @default(now()) @map("created_at")

  @@map("pool_allocations")
}

model ImpactMetric {
  id                   String   @id @default(cuid())
  publicGoodsProjectId String   @map("public_goods_project_id")
  metricName           String   @map("metric_name")
  metricValue          String   @map("metric_value")
  unit                 String?
  timestamp            DateTime @default(now())
  verified             Boolean  @default(false)
  verificationSource   String?  @map("verification_source")
  createdAt            DateTime @default(now()) @map("created_at")

  @@index([publicGoodsProjectId])
  @@index([metricName])
  @@map("impact_metrics")
}

model IntegrationConfig {
  id                   String               @id @default(cuid())
  platform             IntegrationPlatform
  config               Json
  isActive             Boolean              @default(true) @map("is_active")
  lastSyncAt           DateTime?            @map("last_sync_at")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  @@unique([platform])
  @@map("integration_configs")
}

enum FundingRoundType {
  QUADRATIC
  RETROACTIVE
  IMPACT_MARKET
}

enum FundingRoundStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ProjectParticipationStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum CertificateStatus {
  ACTIVE
  BURNED
  TRANSFERRED
  EXPIRED
}

enum FundingStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum MatchingPoolSource {
  PROTOCOL_FEES
  DIRECT_DEPOSIT
  TREASURY
  EXTERNAL_GRANT
}

enum IntegrationPlatform {
  GITCOIN
  CLR_FUND
  GITHUB
  DISCORD
}

// Trading Competition Models

model TradingCompetition {
  id                  String               @id @default(cuid())
  title               String
  description         String?
  type                CompetitionType
  durationType        DurationType
  startTime           DateTime             @map("start_time")
  endTime             DateTime             @map("end_time")
  status              CompetitionStatus    @default(UPCOMING)
  prizePool           Decimal              @default(0) @map("prize_pool")
  maxParticipants     Int?                 @map("max_participants")
  minDeposit          Decimal              @default(0) @map("min_deposit")
  requiredKycTier     Int                  @default(0) @map("required_kyc_tier")
  entryFee            Decimal              @default(0) @map("entry_fee")
  prizeDistribution   Json                 @map("prize_distribution")
  rules               Json?
  createdBy           String               @map("created_by")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  // Relations
  participants        CompetitionParticipant[]
  leaderboard         CompetitionLeaderboard[]
  trades              CompetitionTrade[]
  achievements         CompetitionAchievement[]
  antiCheatFlags      AntiCheatFlag[]
  prizeDistributions  PrizeDistribution[]

  @@map("trading_competitions")
}

model CompetitionParticipant {
  id             String     @id @default(cuid())
  competitionId  String     @map("competition_id")
  competition    TradingCompetition @relation(fields: [competitionId], references: [id])
  userId         String     @map("user_id")
  user           User       @relation(fields: [userId], references: [id])
  status         ParticipantStatus @default(REGISTERED)
  joinedAt       DateTime   @default(now()) @map("joined_at")
  initialBalance Decimal    @default(0) @map("initial_balance")
  finalBalance   Decimal?   @map("final_balance")
  totalVolume    Decimal    @default(0) @map("total_volume")
  totalReturn    Decimal    @default(0) @map("total_return")
  sharpeRatio    Decimal?   @map("sharpe_ratio")
  maxDrawdown    Decimal    @default(0) @map("max_drawdown")
  winRate        Decimal    @default(0) @map("win_rate")
  rank           Int?
  prizeAmount    Decimal?   @map("prize_amount")
  disqualified   Boolean    @default(false) @map("disqualified")
  disqualificationReason String? @map("disqualification_reason")
  
  // Relations
  trades         CompetitionTrade[]
  
  @@unique([competitionId, userId])
  @@map("competition_participants")
}

model CompetitionTrade {
  id              String     @id @default(cuid())
  competitionId   String     @map("competition_id")
  competition     TradingCompetition @relation(fields: [competitionId], references: [id])
  participantId   String     @map("participant_id")
  participant     CompetitionParticipant @relation(fields: [participantId], references: [id])
  userId          String     @map("user_id")
  asset           String
  side            TradeSide
  quantity        Decimal
  price           Decimal
  totalValue      Decimal    @map("total_value")
  fee             Decimal    @default(0)
  timestamp       DateTime   @default(now())
  transactionHash String?    @map("transaction_hash")
  profitLoss      Decimal?   @map("profit_loss")
  
  @@index([competitionId, userId])
  @@index([participantId])
  @@index([timestamp])
  @@map("competition_trades")
}

model CompetitionLeaderboard {
  id             String     @id @default(cuid())
  competitionId  String     @map("competition_id")
  competition    TradingCompetition @relation(fields: [competitionId], references: [id])
  userId         String     @map("user_id")
  user           User       @relation(fields: [userId], references: [id])
  rank           Int
  score          Decimal
  totalReturn    Decimal    @map("total_return")
  totalVolume    Decimal    @map("total_volume")
  sharpeRatio    Decimal?   @map("sharpe_ratio")
  maxDrawdown    Decimal    @map("max_drawdown")
  winRate        Decimal    @default(0) @map("win_rate")
  lastUpdated    DateTime   @default(now()) @map("last_updated")
  
  @@unique([competitionId, userId])
  @@index([competitionId, rank])
  @@map("competition_leaderboard")
}

model CompetitionAchievement {
