// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  walletAddress   String   @unique @map("wallet_address")
  profileData     Json?    @map("profile_data")
  reputationScore Int      @default(0) @map("reputation_score")
  trustScore      Int      @default(500) @map("trust_score")
  reputationLevel String   @default("BRONZE") @map("reputation_level")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Notification fields
  email            String? @unique
  pushSubscription Json?   @map("push_subscription")

  // Relations
  createdProjects      Project[]            @relation("ProjectCreator")
  contributions        Contribution[]
  reputationHistory    ReputationHistory[]
  notificationSettings NotificationSetting?
  notifications        Notification[]
  weeklySummaries      WeeklyReputationSummary[]


  @@map("users")
}

model Project {
  id           String        @id @default(cuid())
  contractId   String        @unique @map("contract_id")
  creatorId    String        @map("creator_id")
  creator      User          @relation("ProjectCreator", fields: [creatorId], references: [id])
  title        String
  description  String?
  category     String
  goal         BigInt
  currentFunds BigInt        @default(0) @map("current_funds")
  deadline     DateTime
  ipfsHash     String?       @map("ipfs_hash")
  status       ProjectStatus @default(ACTIVE)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  // Relations
  contributions Contribution[]
  milestones    Milestone[]
  publicGoodsProject PublicGoodsProject?

  @@map("projects")
}

model Contribution {
  id              String   @id @default(cuid())
  transactionHash String   @unique @map("transaction_hash")
  investorId      String   @map("investor_id")
  investor        User     @relation(fields: [investorId], references: [id])
  projectId       String   @map("project_id")
  project         Project  @relation(fields: [projectId], references: [id])
  amount          BigInt
  timestamp       DateTime @default(now())
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("contributions")
}

model Milestone {
  id             String          @id @default(cuid())
  projectId      String          @map("project_id")
  project        Project         @relation(fields: [projectId], references: [id])
  contractMilestoneId String?    @map("contract_milestone_id")
  title          String
  description    String?
  fundingAmount  BigInt          @map("funding_amount")
  status         MilestoneStatus @default(PENDING)
  completionDate DateTime?       @map("completion_date")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@unique([projectId, contractMilestoneId])
  @@index([projectId, contractMilestoneId])
  @@map("milestones")
}

model ReputationHistory {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  scoreChange Int      @map("score_change")
  reason      String
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("reputation_history")
}


}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  SUSPENDED
}

enum MilestoneStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  FUNDED
}

model LedgerCursor {
  id             String   @id @default(cuid())
  network        String   @unique
  lastLedgerSeq  Int      @map("last_ledger_seq")
  lastLedgerHash String?  @map("last_ledger_hash")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("ledger_cursors")
}

model ProcessedEvent {
  id              String   @id @default(cuid())
  eventId         String   @unique @map("event_id")
  network         String
  ledgerSeq       Int      @map("ledger_seq")
  contractId      String   @map("contract_id")
  eventType       String   @map("event_type")
  transactionHash String   @map("transaction_hash")
  processedAt     DateTime @default(now()) @map("processed_at")

  @@index([network, ledgerSeq])
  @@index([contractId, eventType])
  @@map("processed_events")
}

model IndexerLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  metadata  Json?
  timestamp DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")

  @@index([timestamp])
  @@index([level])
  @@map("indexer_logs")
}

model NotificationSetting {
  id                        String   @id @default(cuid())
  userId                    String   @unique @map("user_id")
  user                      User     @relation(fields: [userId], references: [id])
  emailEnabled              Boolean  @default(true) @map("email_enabled")
  pushEnabled               Boolean  @default(false) @map("push_enabled")
  notifyContributions       Boolean  @default(true) @map("notify_contributions")
  notifyMilestones          Boolean  @default(true) @map("notify_milestones")
  notifyDeadlines           Boolean  @default(true) @map("notify_deadlines")
  notifyReputationChanges   Boolean  @default(true) @map("notify_reputation_changes")
  notifyLevelUps            Boolean  @default(true) @map("notify_level_ups")
  notifyWeeklySummary       Boolean  @default(true) @map("notify_weekly_summary")
  reputationChangeThreshold Int      @default(50) @map("reputation_change_threshold")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  @@map("notification_settings")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  data      Json? // Optional metadata (e.g., projectId)
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId])
  @@map("notifications")
}

model EmailOutbox {
  id        String      @id @default(cuid())
  to        String
  subject   String
  html      String
  status    EmailStatus @default(PENDING)
  attempts  Int         @default(0)
  lastError String?     @map("last_error")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([status])
  @@map("email_outbox")
}

model NotificationOutbox {
  id             String              @id @default(cuid())
  notificationId String?             @map("notification_id")
  userId         String              @map("user_id")
  channel        NotificationChannel
  status         DeliveryStatus      @default(PENDING)
  dedupKey       String              @unique @map("dedup_key")
  payload        Json
  attempts       Int                 @default(0)
  maxAttempts    Int                 @default(3) @map("max_attempts")
  nextRetryAt    DateTime            @default(now()) @map("next_retry_at")
  lastAttemptAt  DateTime?           @map("last_attempt_at")
  retryDisabled  Boolean             @default(false) @map("retry_disabled")
  lastError      String?             @map("last_error")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@index([status, nextRetryAt])
  @@index([userId, channel])
  @@map("notification_outbox")
}

enum NotificationType {
  CONTRIBUTION
  MILESTONE
  DEADLINE
  SYSTEM
  REPUTATION_CHANGE
  LEVEL_UP
  WEEKLY_REPUTATION_SUMMARY
  REPUTATION_MILESTONE
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationChannel {
  EMAIL
  PUSH
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
}

// Insurance Module Models

enum RiskType {
  PROJECT_FAILURE
  SMART_CONTRACT_EXPLOIT
  MARKET_VOLATILITY
  PARAMETRIC_WEATHER
}

enum PolicyStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  CLAIMED
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model InsurancePolicy {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id])
  poolId         String    @map("pool_id")
  pool           InsurancePool @relation(fields: [poolId], references: [id])
  riskType       RiskType  @map("risk_type")
  premium        Decimal   @map("premium")
  coverageAmount Decimal   @map("coverage_amount")
  status         PolicyStatus @default(ACTIVE)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  claims         Claim[]

  @@map("insurance_policies")
}

model InsurancePool {
  id            String   @id @default(cuid())
  name          String
  capital       Decimal  @default(0)
  lockedCapital Decimal  @default(0) @map("locked_capital")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  insurancePolicies    InsurancePolicy[]
  reinsuranceContracts ReinsuranceContract[]
  claims               Claim[]

  @@map("insurance_pools")
}

model Claim {
  id           String      @id @default(cuid())
  policyId     String      @map("policy_id")
  policy       InsurancePolicy @relation(fields: [policyId], references: [id])
  poolId       String?     @map("pool_id")
  pool         InsurancePool? @relation(fields: [poolId], references: [id])
  claimAmount  Decimal     @map("claim_amount")
  status       ClaimStatus @default(PENDING)
  payoutAmount Decimal?    @map("payout_amount")
  createdAt    DateTime    @default(now()) @map("created_at")

  @@map("claims")
}

model ReinsuranceContract {
  id             String   @id @default(cuid())
  poolId         String   @map("pool_id")
  pool           InsurancePool @relation(fields: [poolId], references: [id])
  coverageLimit  Decimal  @map("coverage_limit")
  premiumRate    Decimal  @map("premium_rate")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("reinsurance_contracts")
}

model ReputationTip {
  id          String   @id @default(cuid())
  category    String   // e.g., "transactions", "community", "projects"
  title       String
  description String
  impact      String   // "HIGH", "MEDIUM", "LOW"
  difficulty  String   // "EASY", "MEDIUM", "HARD"
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("reputation_tips")
}

model WeeklyReputationSummary {
  id                    String   @id @default(cuid())
  userId                String   @map("user_id")
  user                  User     @relation(fields: [userId], references: [id])
  weekStartDate         DateTime @map("week_start_date")
  previousScore         Int      @map("previous_score")
  currentScore          Int      @map("current_score")
  scoreChange           Int      @map("score_change")
  level                 String
  activitiesCount       Int      @map("activities_count")
  topActivityType       String?  @map("top_activity_type")
  improvementTips       Json?    @map("improvement_tips")
  emailSent             Boolean  @default(false) @map("email_sent")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@unique([userId, weekStartDate])
  @@map("weekly_reputation_summaries")
}

  COMPLETED
  FAILED
}

