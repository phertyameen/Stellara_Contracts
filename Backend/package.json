{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend services for the project",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:create": "prisma migrate dev --create-only",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:reset": "prisma migrate reset",
    "db:migrate:diff": "prisma migrate diff --from-migrations ./prisma/migrations --to-schema ./prisma/schema.prisma --shadow-database-url $SHADOW_DATABASE_URL",
    "db:rollback": "ts-node prisma/scripts/rollback.ts",
    "db:rollback:list": "ts-node prisma/scripts/rollback.ts --list",
    "db:seed": "ts-node prisma/seed.ts",
    "db:pre-deploy": "ts-node prisma/scripts/pre-deploy-check.ts",
    "db:studio": "prisma studio",
    "prepare": "cd .. && husky install backend/.husky",
    "backup:trigger": "ts-node scripts/trigger-backup.ts",
    "backup:verify": "ts-node scripts/verify-backup.ts",
    "backup:restore": "ts-node scripts/restore.ts",
    "backup:status": "ts-node scripts/backup-status.ts",
    "backup:cleanup": "ts-node scripts/cleanup-backups.ts",
    "dr:drill": "ts-node scripts/dr-drill.ts",
    "deploy:blue-green": "ts-node scripts/blue-green-deploy.ts",
    "deploy:rollback": "ts-node scripts/blue-green-rollback.ts"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1016.0",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.4.22",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/adapter-pg": "^7.5.0",
    "@sendgrid/mail": "^8.1.6",
    "@stellar/stellar-base": "^11.0.0",
    "@stellar/stellar-sdk": "^11.3.0",
    "amqplib": "^0.10.9",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.71.1",
    "cache-manager-ioredis-yet": "^2.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cls-hooked": "^4.2.2",
    "cookie-parser": "^1.4.7",
    "handlebars": "^4.7.8",
    "ioredis": "^5.10.1",
    "ipfs-http-client": "^60.0.1",
    "lodash": "^4.17.23",
    "nestjs-pino": "^4.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "pino-pretty": "^11.0.0",
    "rxjs": "^7.8.2",
    "sanitize-html": "^2.17.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "stripe": "^17.7.0",
    "twilio": "^5.13.1",
    "typeorm": "^0.3.28",
    "ua-parser-js": "^2.0.9",
    "uuid": "^10.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@prisma/client": "^7.5.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^8.0.0",
    "jest": "^29.5.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "prisma": "^7.5.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}